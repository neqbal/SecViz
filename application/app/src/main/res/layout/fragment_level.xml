<?xml version="1.0" encoding="utf-8"?>
<!-- Root: DrawerLayout so the hex panel slides in from the right -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ════ Main content ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_primary"
        android:padding="12dp">

        <!-- Level title bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_level_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tv_level_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_peek_assembly"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/peek_assembly"
                android:textSize="12sp"/>

            <!-- Objdump viewer — shown only for Level 2B -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_objdump"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="{ } Objdump"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_menu"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:text="⋮"
                android:textSize="20sp"
                android:textColor="@color/text_muted"
                app:iconPadding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </LinearLayout>


        <!-- Code viewer -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_code"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            app:cardBackgroundColor="@color/bg_surface"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_code"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:clipToPadding="false"/>
        </androidx.cardview.widget.CardView>

        <!-- Terminal / Console -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.2"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/bg_elevated"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/bg_surface">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="●"
                        android:textColor="@color/success"
                        android:textSize="10sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/terminal_label"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_console"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stack Architecture Visualizer -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_stack_visualizer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/bg_elevated"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <com.example.secviz.ui.views.StackCanvasView
                    android:id="@+id/stack_canvas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </androidx.core.widget.NestedScrollView>
        </androidx.cardview.widget.CardView>

        <!-- ── Register State Timeline strip ──────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_register_timeline"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/bg_elevated"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="  ● Register Timeline  —  RIP · RSP · RBP per step"
                    android:textColor="@color/text_muted"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:paddingVertical="5dp"
                    android:background="@color/bg_surface"/>

                <!-- Horizontal scroll of snapshot cards -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_register_timeline"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:clipToPadding="false"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Status Info Box -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/bg_elevated"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_status_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_status_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>

                <!-- Input form (shown only when step == 4) -->
                <LinearLayout
                    android:id="@+id/layout_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/enter_payload"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_muted"
                                android:fontFamily="monospace"
                                android:inputType="text"
                                android:imeOptions="actionSend"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_send"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/send"/>
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp">

                        <LinearLayout
                            android:id="@+id/layout_presets"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"/>
                    </HorizontalScrollView>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Control buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_step"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/next_step"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_stage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/next_stage"
                android:backgroundTint="@color/success"/>
        </LinearLayout>

        <!-- Snackbar anchor -->
        <View
            android:id="@+id/snackbar_anchor"
            android:layout_width="match_parent"
            android:layout_height="1dp"/>

    </LinearLayout>

    <!-- ════ Right-side Hex Dump Drawer ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/drawer_hex"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:elevation="8dp">

        <!-- Drawer header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical"
            android:background="@color/bg_elevated">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="@color/accent"
                android:textSize="10sp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Memory Hex Dump"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp"/>

            <!-- Close button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_hex_close"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="✕"
                android:textSize="14sp"
                android:textColor="@color/text_muted"/>
        </LinearLayout>

        <!-- Column labels -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  Address    00 01 02 03 04 05 06 07   ASCII"
            android:textColor="@color/text_muted"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@color/bg_primary"/>

        <!-- Scrollable hex rows -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_hex_dump"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:padding="4dp"
                android:clipToPadding="false"/>
        </HorizontalScrollView>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
