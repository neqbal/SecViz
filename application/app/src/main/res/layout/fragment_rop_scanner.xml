<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_scanner"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_surface"
        app:title="Gadget Scanner"
        app:titleTextColor="@color/accent"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:navigationIconTint="@color/text_muted" />

    <!-- Status line -->
    <TextView
        android:id="@+id/tv_scanner_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:fontFamily="monospace"
        android:text="Scanning .text section for ret-ended gadgets..."
        android:textColor="@color/text_muted"
        android:textSize="13sp" />

    <!-- Scan progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_scanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        app:indicatorColor="@color/accent"
        app:trackColor="@color/bg_surface" />

    <!-- Gadget list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_gadgets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp"
        android:visibility="gone"
        tools:listitem="@layout/item_rop_gadget" />

    <!-- Inspector panel -->
    <LinearLayout
        android:id="@+id/panel_inspector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:padding="16dp"
        android:elevation="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GADGET INSPECTOR"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_inspector_asm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/accent"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="pop rdi ; ret" />

        <TextView
            android:id="@+id/tv_inspector_addr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            tools:text="0x0000000000401234" />

        <TextView
            android:id="@+id/tv_inspector_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            tools:text="Pops the top value from the stack into RDI." />

        <TextView
            android:id="@+id/tv_inspector_alias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:textColor="@color/success"
            android:textSize="12sp"
            tools:text="alias: pop_rdi" />

    </LinearLayout>

</LinearLayout>
