<?xml version="1.0" encoding="utf-8"?>
<!--
    crypto_activity_key_exchange.xml  —  CryptoKeyExchange
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#0D1117">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#161B22">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎨  The Color of Keys"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#C9D1D9"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Key Exchange"
            android:textSize="11sp"
            android:textColor="#58A6FF"
            android:background="@drawable/bg_badge_coming_soon"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#58A6FF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Explanation card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="#30363D"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="You are Eve — the eavesdropper. You can see the public color and each party's mixed color. Try to figure out their secret colors by matching below. In real Diffie-Hellman, the &#34;mixing&#34; is a one-way function — impossible to reverse."
                    android:textColor="#8B949E"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Public Color -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PUBLIC SHARED COLOR"
                android:textSize="10sp"
                android:textColor="#8B949E"
                android:letterSpacing="0.12"
                android:paddingBottom="8dp"/>

            <View
                android:id="@+id/viewPublicColor"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="20dp"/>

            <!-- Alice -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#30363D"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ALICE'S MIXED COLOR (INTERCEPTED)"
                android:textSize="10sp"
                android:textColor="#8B949E"
                android:letterSpacing="0.12"
                android:paddingBottom="8dp"/>

            <View
                android:id="@+id/viewAliceMixed"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guess Alice's secret color:"
                android:textColor="#C9D1D9"
                android:textSize="13sp"
                android:paddingBottom="8dp"/>

            <View
                android:id="@+id/viewAliceGuessPreview"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="#000000"
                android:layout_marginBottom="8dp"/>

            <SeekBar android:id="@+id/seekAliceR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255"
                android:progressTint="#F85149"
                android:thumbTint="#F85149"/>
            <SeekBar android:id="@+id/seekAliceG"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255"
                android:progressTint="#3FB950"
                android:thumbTint="#3FB950"/>
            <SeekBar android:id="@+id/seekAliceB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255"
                android:progressTint="#58A6FF"
                android:thumbTint="#58A6FF"
                android:layout_marginBottom="20dp"/>

            <!-- Bob -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#30363D"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BOB'S MIXED COLOR (INTERCEPTED)"
                android:textSize="10sp"
                android:textColor="#8B949E"
                android:letterSpacing="0.12"
                android:paddingBottom="8dp"/>

            <View
                android:id="@+id/viewBobMixed"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guess Bob's secret color:"
                android:textColor="#C9D1D9"
                android:textSize="13sp"
                android:paddingBottom="8dp"/>

            <View
                android:id="@+id/viewBobGuessPreview"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="#000000"
                android:layout_marginBottom="8dp"/>

            <SeekBar android:id="@+id/seekBobR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255"
                android:progressTint="#F85149"
                android:thumbTint="#F85149"/>
            <SeekBar android:id="@+id/seekBobG"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255"
                android:progressTint="#3FB950"
                android:thumbTint="#3FB950"/>
            <SeekBar android:id="@+id/seekBobB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255"
                android:progressTint="#58A6FF"
                android:thumbTint="#58A6FF"
                android:layout_marginBottom="24dp"/>

            <!-- Reveal button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReveal"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Reveal Secrets &amp; Score"
                android:textColor="#0D1117"
                android:textSize="14sp"
                app:backgroundTint="#58A6FF"
                app:cornerRadius="8dp"/>

            <!-- Results -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="#30363D"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:textSize="14sp"
                    android:textColor="#C9D1D9"
                    android:lineSpacingMultiplier="1.5"
                    android:visibility="visible"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>