<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="180dp"
    android:layout_height="match_parent"
    android:layout_marginEnd="8dp"
    app:cardBackgroundColor="#00000000"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp">

    <!-- Bordered container — border color injected at runtime -->
    <LinearLayout
        android:id="@+id/snapshot_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/bg_snapshot_card">

        <!-- Step label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tv_snap_index"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#58A6FF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:paddingEnd="6dp"/>

            <TextView
                android:id="@+id/tv_snap_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#C9D1D9"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#30363D"
            android:layout_marginBottom="6dp"/>

        <!-- RIP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="3dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="RIP"
                android:textColor="#8B949E"
                android:textSize="9sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tv_snap_rip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#A371F7"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- RSP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="3dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="RSP"
                android:textColor="#8B949E"
                android:textSize="9sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tv_snap_rsp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#58A6FF"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- RBP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="RBP"
                android:textColor="#8B949E"
                android:textSize="9sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tv_snap_rbp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#3FB950"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
