<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- ── Toolbar ── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_editor"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_surface"
        app:title="ROP Chain Editor"
        app:titleTextColor="@color/accent"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:navigationIconTint="@color/text_muted" />

    <!-- ── Alias Reference Bar ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0d1117"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <LinearLayout
            android:id="@+id/ll_alias_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

    </HorizontalScrollView>

    <!-- ── Main Editor Area ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Line Numbers -->
        <LinearLayout
            android:id="@+id/ll_line_numbers"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#0d1117"
            android:paddingTop="8dp" />

        <!-- Editor Input -->
        <EditText
            android:id="@+id/et_rop_editor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="top|start"
            android:padding="8dp"
            android:background="@color/bg_primary"
            android:fontFamily="monospace"
            android:inputType="textMultiLine|textNoSuggestions"
            android:textColor="#d4d4d4"
            android:textSize="13sp"
            android:textCursorDrawable="@null"
            android:hint="# One value per line&#10;# e.g. pop_rdi, 0x402000, 59"
            android:textColorHint="#40c9d1d9" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/border" />

        <!-- Live Preview Panel -->
        <ScrollView
            android:id="@+id/sv_preview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0d1117"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/ll_preview_lines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />

        </ScrollView>
    </LinearLayout>

    <!-- ── Status/Validation Footer ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_validation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            tools:text="9 entries · 72 bytes · ready" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_execute_payload"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send Payload"
            android:textSize="12sp"
            android:backgroundTint="@color/success"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>
